# =============================================================================
# .gitattributes Template — LFS, Diff Drivers, Merge Strategies
# =============================================================================
#
# Usage: Copy this file to your repository root as .gitattributes
#        Customize the patterns for your project's needs.
#
# Sections:
#   1. Line ending normalization
#   2. Git LFS patterns
#   3. Custom diff drivers
#   4. Merge strategies
#   5. Export and archive settings
#   6. Linguist overrides (GitHub language stats)
#
# =============================================================================

# ─── Line Ending Normalization ───────────────────────────────────────────────
# Normalize all text files to LF in the repo, native on checkout

* text=auto

# Explicit text files
*.md          text
*.txt         text
*.csv         text
*.tsv         text
*.xml         text
*.html        text
*.css         text
*.scss        text
*.less        text
*.js          text
*.jsx         text
*.ts          text
*.tsx         text
*.json        text
*.yaml        text
*.yml         text
*.toml        text
*.ini         text
*.cfg         text
*.conf        text
*.py          text
*.rb          text
*.go          text
*.rs          text
*.java        text
*.kt          text
*.swift       text
*.c           text
*.cpp         text
*.h           text
*.hpp         text
*.sh          text eol=lf
*.bash        text eol=lf
*.zsh         text eol=lf
*.fish        text eol=lf
Makefile      text eol=lf
Dockerfile    text eol=lf
*.sql         text

# Windows-specific files
*.bat         text eol=crlf
*.cmd         text eol=crlf
*.ps1         text eol=crlf
*.sln         text eol=crlf
*.csproj      text eol=crlf

# ─── Git LFS ────────────────────────────────────────────────────────────────
# Track large binary files with Git LFS
# Install: git lfs install
# After adding patterns: git lfs migrate import --include="*.ext"

# Images
*.png         filter=lfs diff=lfs merge=lfs -text
*.jpg         filter=lfs diff=lfs merge=lfs -text
*.jpeg        filter=lfs diff=lfs merge=lfs -text
*.gif         filter=lfs diff=lfs merge=lfs -text
*.bmp         filter=lfs diff=lfs merge=lfs -text
*.ico         filter=lfs diff=lfs merge=lfs -text
*.webp        filter=lfs diff=lfs merge=lfs -text
*.svg         filter=lfs diff=lfs merge=lfs -text

# Design files
*.psd         filter=lfs diff=lfs merge=lfs -text
*.ai          filter=lfs diff=lfs merge=lfs -text
*.sketch      filter=lfs diff=lfs merge=lfs -text
*.fig         filter=lfs diff=lfs merge=lfs -text
*.xd          filter=lfs diff=lfs merge=lfs -text

# Fonts
*.woff        filter=lfs diff=lfs merge=lfs -text
*.woff2       filter=lfs diff=lfs merge=lfs -text
*.ttf         filter=lfs diff=lfs merge=lfs -text
*.otf         filter=lfs diff=lfs merge=lfs -text
*.eot         filter=lfs diff=lfs merge=lfs -text

# Audio/Video
*.mp3         filter=lfs diff=lfs merge=lfs -text
*.mp4         filter=lfs diff=lfs merge=lfs -text
*.wav         filter=lfs diff=lfs merge=lfs -text
*.ogg         filter=lfs diff=lfs merge=lfs -text
*.webm        filter=lfs diff=lfs merge=lfs -text
*.mov         filter=lfs diff=lfs merge=lfs -text
*.avi         filter=lfs diff=lfs merge=lfs -text

# Archives
*.zip         filter=lfs diff=lfs merge=lfs -text
*.tar.gz      filter=lfs diff=lfs merge=lfs -text
*.tgz         filter=lfs diff=lfs merge=lfs -text
*.rar         filter=lfs diff=lfs merge=lfs -text
*.7z          filter=lfs diff=lfs merge=lfs -text

# Documents
