# ─── Custom Diff Drivers ────────────────────────────────────────────────────
# Configure in .gitconfig:
#   [diff "json"]
#     textconv = python3 -m json.tool
#   [diff "csv"]
#     textconv = column -t -s,
#   [diff "exif"]
#     textconv = exiftool
#   [diff "word"]
#     textconv = pandoc --to=plain

*.json        diff=json
*.csv         diff=csv

# Suppress diffs for generated/minified files
*.min.js      -diff
*.min.css     -diff
*.map         -diff

# ─── Merge Strategies ───────────────────────────────────────────────────────
# Avoid merge conflicts on auto-generated files by always keeping one side

# Lock files — always keep ours (the version on the branch being merged into)
package-lock.json   merge=ours
yarn.lock           merge=ours
pnpm-lock.yaml      merge=ours
Pipfile.lock        merge=ours
poetry.lock         merge=ours
Gemfile.lock        merge=ours
Cargo.lock          merge=ours
go.sum              merge=ours
composer.lock       merge=ours

# Generated files — force manual resolution (never auto-merge)
*.generated.ts      -merge
*.generated.go      -merge
*.g.dart            -merge

# ─── Export / Archive Settings ───────────────────────────────────────────────
# Files to exclude from `git archive` exports

.gitattributes      export-ignore
.gitignore          export-ignore
.gitmodules         export-ignore
.editorconfig       export-ignore
.eslintrc*          export-ignore
.prettierrc*        export-ignore
.stylelintrc*       export-ignore
.github/            export-ignore
.husky/             export-ignore
.githooks/          export-ignore
.vscode/            export-ignore
.idea/              export-ignore
tests/              export-ignore
__tests__/          export-ignore
spec/               export-ignore
*.test.*            export-ignore
*.spec.*            export-ignore
Makefile            export-ignore
docker-compose*.yml export-ignore
Dockerfile*         export-ignore

# ─── Linguist Overrides (GitHub Language Stats) ──────────────────────────────
# Customize what GitHub counts for repository language statistics

# Exclude from stats
vendor/**           linguist-vendored
third_party/**      linguist-vendored
node_modules/**     linguist-vendored
dist/**             linguist-generated
build/**            linguist-generated
*.generated.*       linguist-generated
*.min.js            linguist-generated
*.min.css           linguist-generated
*.lock              linguist-generated

# Mark documentation
docs/**             linguist-documentation
*.md                linguist-documentation

# Force language detection
*.h                 linguist-language=C
Jenkinsfile         linguist-language=Groovy
