# direnv integration for Nix flakes
#
# This file automatically activates the Nix devShell when you cd into the project.
#
# Prerequisites:
#   1. Install direnv: nix profile install nixpkgs#direnv
#   2. Install nix-direnv (recommended for caching): nix profile install nixpkgs#nix-direnv
#   3. Hook direnv into your shell:
#        bash: eval "$(direnv hook bash)"   # add to ~/.bashrc
#        zsh:  eval "$(direnv hook zsh)"    # add to ~/.zshrc
#        fish: direnv hook fish | source    # add to ~/.config/fish/config.fish
#   4. Run: direnv allow
#
# nix-direnv caches the devShell evaluation, so subsequent activations are instant.
# It also creates a GC root, preventing your devShell from being garbage collected.
#
# For named shells: use flake .#shellName
# For extra env vars: add export lines below

use flake

# Optional: load .env file if present (for local secrets — never commit .env!)
# dotenv_if_exists .env

# Optional: watch extra files for changes (triggers re-evaluation)
# watch_file custom-config.nix

# Optional: additional environment variables
# export DATABASE_URL="postgresql://localhost/dev"
# export AWS_PROFILE="dev"
