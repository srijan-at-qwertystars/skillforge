# ═══════════════════════════════════════════════════════════
# Docker Compose Environment Variables
# Copy to .env and fill in values: cp .env.example .env
# ═══════════════════════════════════════════════════════════

# ─── Project ───────────────────────────────────────────────
COMPOSE_PROJECT_NAME=myapp
# COMPOSE_FILE=compose.yaml                # Override compose file
# COMPOSE_PROFILES=dev,monitoring          # Active profiles

# ─── Application ──────────────────────────────────────────
APP_ENV=production
APP_PORT=3000
API_PORT=4000
LOG_LEVEL=info
# TAG=latest                               # Image tag for deployments

# ─── Database (PostgreSQL) ────────────────────────────────
DB_NAME=appdb
DB_USER=app
DB_PASSWORD=CHANGEME_use_secrets_in_prod
DB_PORT=5432
# DB_HOST=db                               # Service name in compose network

# ─── Cache (Redis) ────────────────────────────────────────
REDIS_MAXMEM=256mb
REDIS_PORT=6379

# ─── Reverse Proxy (Nginx) ────────────────────────────────
HTTP_PORT=80
HTTPS_PORT=443

# ─── Monitoring ───────────────────────────────────────────
GRAFANA_PASSWORD=CHANGEME
GRAFANA_PORT=3001
GRAFANA_URL=http://localhost:3001
PROMETHEUS_PORT=9090
PROM_RETENTION=15d
CADVISOR_PORT=8081
ALERTMANAGER_PORT=9093

# ─── CI/CD ────────────────────────────────────────────────
# CI_REGISTRY=ghcr.io/myorg               # Container registry for CI cache

# ─── Notes ────────────────────────────────────────────────
# - This file is for compose.yaml interpolation (${VAR} syntax)
# - It is NOT auto-injected into containers; use env_file: for that
# - Never commit real secrets — use Docker secrets in production
# - Lines starting with # are comments
# - Format: KEY=value (no spaces around =, no export keyword)
