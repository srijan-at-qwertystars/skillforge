# =============================================================================
# .kamal/secrets — Kamal Secrets File
# =============================================================================
#
# Copy to .kamal/secrets and fill in real values.
# ⚠️  NEVER commit this file to git. Add .kamal/secrets to .gitignore.
#
# Format: KEY=VALUE (one per line, shell-style)
# Supports: literals, shell variables ($VAR), command substitution $(cmd)
#
# Loaded automatically by Kamal. Destination-specific files also supported:
#   .kamal/secrets             — default (always loaded)
#   .kamal/secrets-common      — shared across destinations
#   .kamal/secrets.staging     — loaded with -d staging
#   .kamal/secrets.production  — loaded with -d production
# =============================================================================

# --- Docker Registry ---
# GitHub Container Registry (needs PAT with packages:write scope)
KAMAL_REGISTRY_PASSWORD=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Docker Hub
# KAMAL_REGISTRY_PASSWORD=dckr_pat_xxxxxxxxxxxxxxxxxxxxxxxx

# DigitalOcean Container Registry
# KAMAL_REGISTRY_PASSWORD=dop_v1_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Application Secrets ---
# Rails master key (from config/master.key)
RAILS_MASTER_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret key base (alternative to master key)
# SECRET_KEY_BASE=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Database ---
DATABASE_URL=postgres://myapp:STRONG_PASSWORD_HERE@myapp-db:5432/myapp_production

# PostgreSQL accessory password (used by the Postgres container itself)
POSTGRES_PASSWORD=STRONG_PASSWORD_HERE

# --- Redis ---
# REDIS_URL=redis://myapp-redis:6379/0

# --- Email/SMTP ---
# SMTP_ADDRESS=smtp.example.com
# SMTP_PORT=587
# SMTP_USERNAME=noreply@example.com
# SMTP_PASSWORD=your_smtp_password

# --- Cloud Storage ---
# AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AWS_REGION=us-east-1
# AWS_BUCKET=myapp-production

# --- Monitoring & Error Tracking ---
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
# HONEYBADGER_API_KEY=xxxxxxxx

# --- External APIs ---
# STRIPE_SECRET_KEY=sk_live_xxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxx

# --- Slack Notifications (for deploy hooks) ---
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# =============================================================================
# Using Secret Managers (recommended for production)
# =============================================================================
# 1Password CLI:
# RAILS_MASTER_KEY=$(op read "op://Production/Rails/master-key")
# DATABASE_URL=$(op read "op://Production/Postgres/url")
#
# AWS Secrets Manager:
# DB_PASSWORD=$(aws secretsmanager get-secret-value --secret-id myapp/db --query SecretString --output text | jq -r .password)
#
# Doppler:
# eval $(doppler secrets download --no-file --format env-no-quotes)
#
# Shell environment passthrough:
# RAILS_MASTER_KEY=$RAILS_MASTER_KEY
