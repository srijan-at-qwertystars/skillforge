{
  "uid": "svc-overview-template",
  "title": "Service Overview — TEMPLATE",
  "description": "Production-ready service dashboard template with golden signals, logs, and annotations.",
  "tags": ["template", "service", "production"],
  "schemaVersion": 39,
  "editable": true,
  "graphTooltip": 1,
  "timezone": "utc",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "fiscalYearStartMonth": 0,
  "liveNow": false,
  "weekStart": "",

  "links": [
    {
      "title": "Related Dashboards",
      "type": "dashboards",
      "tags": ["service"],
      "asDropdown": true,
      "includeVars": true,
      "keepTime": true,
      "targetBlank": false,
      "icon": "external link"
    },
    {
      "title": "Runbook",
      "type": "link",
      "url": "https://wiki.internal/runbooks/${__dashboard.uid}",
      "targetBlank": true,
      "icon": "doc"
    }
  ],

  "annotations": {
    "list": [
      {
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "name": "Deployments",
        "iconColor": "blue",
        "target": { "matchAny": true, "tags": ["deploy"], "type": "tags" }
      },
      {
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "name": "Incidents",
        "iconColor": "red",
        "target": { "matchAny": true, "tags": ["incident"], "type": "tags" }
      }
    ]
  },

  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "loki_ds",
        "type": "datasource",
        "query": "loki",
        "current": {},
        "hide": 0
      },
      {
        "name": "namespace",
        "type": "query",
        "datasource": { "uid": "${datasource}" },
        "query": "label_values(up, namespace)",
        "refresh": 1,
        "sort": 1,
        "multi": false,
        "includeAll": false
      },
      {
        "name": "job",
        "type": "query",
        "datasource": { "uid": "${datasource}" },
        "query": "label_values(up{namespace=\"$namespace\"}, job)",
        "refresh": 1,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*"
      },
      {
        "name": "instance",
        "type": "query",
        "datasource": { "uid": "${datasource}" },
        "query": "label_values(up{namespace=\"$namespace\", job=~\"$job\"}, instance)",
        "refresh": 2,
        "sort": 1,
        "multi": true,
        "includeAll": true,
        "allValue": ".*"
      },
      {
        "name": "interval",
        "type": "interval",
        "query": "1m,5m,15m,30m,1h",
        "auto": true,
        "auto_min": "10s",
        "auto_count": 30
      }
    ]
  },

  "panels": [
    {
      "type": "row",
      "title": "Overview",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "panels": []
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Availability",
      "description": "Proportion of successful (non-5xx) requests",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "1 - (sum(rate(http_requests_total{namespace=\"$namespace\", job=~\"$job\", status=~\"5..\"}[$__rate_interval])) / sum(rate(http_requests_total{namespace=\"$namespace\", job=~\"$job\"}[$__rate_interval])))",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.99 },
              { "color": "green", "value": 0.999 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Request Rate",
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace=\"$namespace\", job=~\"$job\"}[$__rate_interval]))",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Error Rate",
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 4 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace=\"$namespace\", job=~\"$job\", status=~\"5..\"}[$__rate_interval])) / sum(rate(http_requests_total{namespace=\"$namespace\", job=~\"$job\"}[$__rate_interval]))",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "P99 Latency",
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 4 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{namespace=\"$namespace\", job=~\"$job\"}[$__rate_interval])))",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Active Instances",
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 4 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "count(up{namespace=\"$namespace\", job=~\"$job\"} == 1)",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Uptime",
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 4 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "min(time() - process_start_time_seconds{namespace=\"$namespace\", job=~\"$job\"})",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "yellow", "value": null },
              { "color": "green", "value": 3600 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      }
    },

    {
      "type": "row",
      "title": "Traffic",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 },
      "panels": []
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Request Rate by Status",
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (status) (rate(http_requests_total{namespace=\"$namespace\", job=~\"$job\"}[$__rate_interval]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "spanNulls": false,
            "showPoints": "never",
            "stacking": { "mode": "none" }
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "/^5/" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/^4/" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/^2/" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Error Rate",
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{namespace=\"$namespace\", job=~\"$job\", status=~\"5..\"}[$__rate_interval])) / sum(rate(http_requests_total{namespace=\"$namespace\", job=~\"$job\"}[$__rate_interval]))",
          "legendFormat": "Error Ratio",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 30,
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.05 }
            ]
          },
          "color": { "mode": "fixed", "fixedColor": "red" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      }
    },

    {
      "type": "row",
      "title": "Latency",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 },
      "panels": []
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Latency Quantiles",
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 8 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket{namespace=\"$namespace\", job=~\"$job\"}[$__rate_interval])))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket{namespace=\"$namespace\", job=~\"$job\"}[$__rate_interval])))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket{namespace=\"$namespace\", job=~\"$job\"}[$__rate_interval])))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "id": 10,
      "type": "heatmap",
      "title": "Latency Distribution",
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 8 },
      "datasource": { "uid": "${datasource}" },
      "targets": [
        {
          "expr": "sum by (le) (rate(http_request_duration_seconds_bucket{namespace=\"$namespace\", job=~\"$job\"}[$__rate_interval]))",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ],
      "options": {
        "calculate": false,
        "yAxis": { "unit": "s" },
        "color": { "scheme": "Oranges", "mode": "scheme" },
        "cellGap": 1
      }
    },

    {
      "type": "row",
      "title": "Resources",
      "collapsed": true,
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 1 },
      "panels": [
        {
          "id": 11,
          "type": "timeseries",
          "title": "CPU Usage",
          "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
          "datasource": { "uid": "${datasource}" },
          "targets": [
            {
              "expr": "sum by (instance) (rate(process_cpu_seconds_total{namespace=\"$namespace\", job=~\"$job\"}[$__rate_interval]))",
              "legendFormat": "{{instance}}",
              "refId": "A"
            }
          ],
          "fieldConfig": { "defaults": { "unit": "percentunit", "custom": { "fillOpacity": 20 } } }
        },
        {
          "id": 12,
          "type": "timeseries",
          "title": "Memory Usage",
          "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
          "datasource": { "uid": "${datasource}" },
          "targets": [
            {
              "expr": "process_resident_memory_bytes{namespace=\"$namespace\", job=~\"$job\"}",
              "legendFormat": "{{instance}}",
              "refId": "A"
            }
          ],
          "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "fillOpacity": 20 } } }
        }
      ]
    },

    {
      "type": "row",
      "title": "Logs",
      "collapsed": true,
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 1 },
      "panels": [
        {
          "id": 13,
          "type": "logs",
          "title": "Application Logs",
          "gridPos": { "x": 0, "y": 33, "w": 24, "h": 10 },
          "datasource": { "uid": "${loki_ds}" },
          "targets": [
            {
              "expr": "{namespace=\"$namespace\", job=~\"$job\"} |= \"\" | json | __error__=\"\"",
              "refId": "A"
            }
          ],
          "options": {
            "showTime": true,
            "wrapLogMessage": true,
            "enableLogDetails": true,
            "sortOrder": "Descending",
            "dedupStrategy": "none"
          }
        }
      ]
    }
  ]
}
