{
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  },
  "imports": {
    "fresh": "jsr:@fresh/core@^2",
    "preact": "npm:preact@^10.22",
    "@preact/signals": "npm:@preact/signals@^1.2",
    "@std/assert": "jsr:@std/assert@^1"
  },
  "tasks": {
    "dev": "deno run -A --watch=routes/,islands/,static/ main.ts",
    "start": "deno run -A main.ts",
    "test": "deno test --allow-read --allow-env",
    "lint": "deno lint",
    "fmt": "deno fmt"
  },
  "fmt": {
    "indentWidth": 2,
    "singleQuote": true
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
