{
  "rabbit_version": "3.13.0",
  "rabbitmq_version": "3.13.0",
  "product_name": "RabbitMQ",
  "product_version": "3.13.0",

  "users": [
    {
      "name": "admin",
      "password_hash": "CHANGE_ME",
      "hashing_algorithm": "rabbit_password_hashing_sha256",
      "tags": ["administrator"],
      "limits": {}
    },
    {
      "name": "app_orders",
      "password_hash": "CHANGE_ME",
      "hashing_algorithm": "rabbit_password_hashing_sha256",
      "tags": ["monitoring"],
      "limits": {}
    },
    {
      "name": "app_payments",
      "password_hash": "CHANGE_ME",
      "hashing_algorithm": "rabbit_password_hashing_sha256",
      "tags": ["monitoring"],
      "limits": {}
    },
    {
      "name": "app_notifications",
      "password_hash": "CHANGE_ME",
      "hashing_algorithm": "rabbit_password_hashing_sha256",
      "tags": [],
      "limits": {}
    },
    {
      "name": "prometheus",
      "password_hash": "CHANGE_ME",
      "hashing_algorithm": "rabbit_password_hashing_sha256",
      "tags": ["monitoring"],
      "limits": {}
    }
  ],

  "vhosts": [
    { "name": "/" },
    { "name": "/production" },
    { "name": "/staging" },
    { "name": "/test" }
  ],

  "permissions": [
    {
      "user": "admin",
      "vhost": "/",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    },
    {
      "user": "admin",
      "vhost": "/production",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    },
    {
      "user": "admin",
      "vhost": "/staging",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    },
    {
      "user": "admin",
      "vhost": "/test",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    },
    {
      "user": "app_orders",
      "vhost": "/production",
      "configure": "^(orders\\.|dlx|dead-letters)",
      "write": "^(orders\\.|dlx|dead-letters)",
      "read": "^(orders\\.|dlx|dead-letters)"
    },
    {
      "user": "app_payments",
      "vhost": "/production",
      "configure": "^(payments\\.|dlx|dead-letters)",
      "write": "^(payments\\.|dlx|dead-letters|orders\\.)",
      "read": "^(payments\\.|dlx|dead-letters|orders\\.)"
    },
    {
      "user": "app_notifications",
      "vhost": "/production",
      "configure": "^(notifications\\.)",
      "write": "^(notifications\\.)",
      "read": "^(notifications\\.|orders\\.|payments\\.)"
    },
    {
      "user": "prometheus",
      "vhost": "/production",
      "configure": "",
      "write": "",
      "read": ".*"
    }
  ],

  "topic_permissions": [
    {
      "user": "app_orders",
      "vhost": "/production",
      "exchange": "orders",
      "write": "order\\..*",
      "read": "order\\..*"
    },
    {
      "user": "app_payments",
      "vhost": "/production",
      "exchange": "payments",
      "write": "payment\\..*",
      "read": "payment\\..*"
    }
  ],

  "parameters": [],
  "global_parameters": [
    {
      "name": "internal_cluster_id",
      "value": "rabbitmq-cluster-production-01"
    }
  ],

  "policies": [
    {
      "vhost": "/production",
      "name": "quorum-default",
      "pattern": "^(?!amq\\.).*",
      "apply-to": "queues",
      "definition": {
        "queue-mode": "default",
        "delivery-limit": 10
      },
      "priority": 0
    },
    {
      "vhost": "/production",
      "name": "ttl-24h",
      "pattern": ".*",
      "apply-to": "queues",
      "definition": {
        "message-ttl": 86400000
      },
      "priority": 1
    },
    {
      "vhost": "/production",
      "name": "ha-quorum",
      "pattern": "^(?!amq\\.).*",
      "apply-to": "quorum_queues",
      "definition": {
        "max-in-memory-length": 10000
      },
      "priority": 2
    },
    {
      "vhost": "/staging",
      "name": "ttl-1h-staging",
      "pattern": ".*",
      "apply-to": "queues",
      "definition": {
        "message-ttl": 3600000,
        "max-length": 10000,
        "overflow": "reject-publish"
      },
      "priority": 0
    }
  ],

  "queues": [
    {
      "name": "orders.processing",
      "vhost": "/production",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-queue-type": "quorum",
        "x-quorum-initial-group-size": 3,
        "x-delivery-limit": 5,
        "x-dead-letter-exchange": "dlx",
        "x-dead-letter-routing-key": "order.failed",
        "x-max-length": 100000,
        "x-overflow": "reject-publish"
      }
    },
    {
      "name": "orders.notifications",
      "vhost": "/production",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-queue-type": "quorum",
        "x-quorum-initial-group-size": 3,
        "x-delivery-limit": 5,
        "x-dead-letter-exchange": "dlx",
        "x-dead-letter-routing-key": "order.notification.failed"
      }
    },
    {
      "name": "payments.processing",
      "vhost": "/production",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-queue-type": "quorum",
        "x-quorum-initial-group-size": 3,
        "x-delivery-limit": 3,
        "x-dead-letter-exchange": "dlx",
        "x-dead-letter-routing-key": "payment.failed",
        "x-max-length": 50000,
        "x-overflow": "reject-publish"
      }
    },
    {
      "name": "notifications.email",
      "vhost": "/production",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-queue-type": "quorum",
        "x-quorum-initial-group-size": 3,
        "x-delivery-limit": 10,
        "x-dead-letter-exchange": "dlx",
        "x-dead-letter-routing-key": "notification.email.failed"
      }
    },
    {
      "name": "notifications.push",
      "vhost": "/production",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-queue-type": "quorum",
        "x-quorum-initial-group-size": 3,
        "x-delivery-limit": 5,
        "x-dead-letter-exchange": "dlx",
        "x-dead-letter-routing-key": "notification.push.failed"
      }
    },
    {
      "name": "dead-letters.parking",
      "vhost": "/production",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-queue-type": "quorum",
        "x-quorum-initial-group-size": 3
      }
    },
    {
      "name": "retry.30s",
      "vhost": "/production",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-queue-type": "quorum",
        "x-message-ttl": 30000,
        "x-dead-letter-exchange": "orders",
        "x-dead-letter-routing-key": "order.created.retry"
      }
    },
    {
      "name": "retry.300s",
      "vhost": "/production",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-queue-type": "quorum",
        "x-message-ttl": 300000,
        "x-dead-letter-exchange": "orders",
        "x-dead-letter-routing-key": "order.created.retry"
      }
    }
  ],

  "exchanges": [
    {
      "name": "orders",
      "vhost": "/production",
      "type": "topic",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {
        "alternate-exchange": "unrouted"
      }
    },
    {
      "name": "payments",
      "vhost": "/production",
      "type": "topic",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {
        "alternate-exchange": "unrouted"
      }
    },
    {
      "name": "notifications",
      "vhost": "/production",
      "type": "fanout",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    },
    {
      "name": "dlx",
      "vhost": "/production",
      "type": "topic",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    },
    {
      "name": "dlx.retry",
      "vhost": "/production",
      "type": "direct",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    },
    {
      "name": "unrouted",
      "vhost": "/production",
      "type": "fanout",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    }
  ],

  "bindings": [
    {
      "source": "orders",
      "vhost": "/production",
      "destination": "orders.processing",
      "destination_type": "queue",
      "routing_key": "order.created.#",
      "arguments": {}
    },
    {
      "source": "orders",
      "vhost": "/production",
      "destination": "orders.notifications",
      "destination_type": "queue",
      "routing_key": "order.#",
      "arguments": {}
    },
    {
      "source": "payments",
      "vhost": "/production",
      "destination": "payments.processing",
      "destination_type": "queue",
      "routing_key": "payment.#",
      "arguments": {}
    },
    {
      "source": "notifications",
      "vhost": "/production",
      "destination": "notifications.email",
      "destination_type": "queue",
      "routing_key": "",
      "arguments": {}
    },
    {
      "source": "notifications",
      "vhost": "/production",
      "destination": "notifications.push",
      "destination_type": "queue",
      "routing_key": "",
      "arguments": {}
    },
    {
      "source": "dlx",
      "vhost": "/production",
      "destination": "dead-letters.parking",
      "destination_type": "queue",
      "routing_key": "#",
      "arguments": {}
    },
    {
      "source": "dlx.retry",
      "vhost": "/production",
      "destination": "retry.30s",
      "destination_type": "queue",
      "routing_key": "retry.30s",
      "arguments": {}
    },
    {
      "source": "dlx.retry",
      "vhost": "/production",
      "destination": "retry.300s",
      "destination_type": "queue",
      "routing_key": "retry.300s",
      "arguments": {}
    },
    {
      "source": "unrouted",
      "vhost": "/production",
      "destination": "dead-letters.parking",
      "destination_type": "queue",
      "routing_key": "",
      "arguments": {}
    }
  ]
}
