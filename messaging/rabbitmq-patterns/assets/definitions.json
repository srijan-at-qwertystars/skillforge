{
  "rabbit_version": "4.0.0",
  "rabbitmq_version": "4.0.0",
  "product_name": "RabbitMQ",
  "product_version": "4.0.0",

  "users": [
    {
      "name": "admin",
      "password_hash": "CHANGE_ME_USE_rabbitmqctl_OR_API",
      "hashing_algorithm": "rabbit_password_hashing_sha256",
      "tags": ["administrator"],
      "limits": {}
    },
    {
      "name": "app_service",
      "password_hash": "CHANGE_ME_USE_rabbitmqctl_OR_API",
      "hashing_algorithm": "rabbit_password_hashing_sha256",
      "tags": ["management"],
      "limits": {}
    },
    {
      "name": "monitoring",
      "password_hash": "CHANGE_ME_USE_rabbitmqctl_OR_API",
      "hashing_algorithm": "rabbit_password_hashing_sha256",
      "tags": ["monitoring"],
      "limits": {}
    }
  ],

  "vhosts": [
    {
      "name": "/",
      "metadata": {
        "description": "Default virtual host",
        "default_queue_type": "quorum"
      }
    },
    {
      "name": "production",
      "metadata": {
        "description": "Production workloads",
        "default_queue_type": "quorum"
      }
    },
    {
      "name": "staging",
      "metadata": {
        "description": "Staging and testing",
        "default_queue_type": "quorum"
      }
    }
  ],

  "permissions": [
    {
      "user": "admin",
      "vhost": "/",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    },
    {
      "user": "admin",
      "vhost": "production",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    },
    {
      "user": "admin",
      "vhost": "staging",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    },
    {
      "user": "app_service",
      "vhost": "production",
      "configure": "^app\\.",
      "write": "^(app\\.|events\\.|dlx)",
      "read": "^(app\\.|events\\.|dlx)"
    },
    {
      "user": "app_service",
      "vhost": "staging",
      "configure": ".*",
      "write": ".*",
      "read": ".*"
    },
    {
      "user": "monitoring",
      "vhost": "/",
      "configure": "",
      "write": "",
      "read": ".*"
    },
    {
      "user": "monitoring",
      "vhost": "production",
      "configure": "",
      "write": "",
      "read": ".*"
    }
  ],

  "topic_permissions": [
    {
      "user": "app_service",
      "vhost": "production",
      "exchange": "events",
      "write": "^app\\..*",
      "read": ".*"
    }
  ],

  "parameters": [],
  "global_parameters": [
    {
      "name": "internal_cluster_id",
      "value": "rabbitmq-cluster-001"
    }
  ],

  "exchanges": [
    {
      "name": "events",
      "vhost": "production",
      "type": "topic",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    },
    {
      "name": "commands",
      "vhost": "production",
      "type": "direct",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    },
    {
      "name": "notifications",
      "vhost": "production",
      "type": "fanout",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    },
    {
      "name": "dlx",
      "vhost": "production",
      "type": "direct",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    },
    {
      "name": "dlx",
      "vhost": "staging",
      "type": "direct",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    },
    {
      "name": "events",
      "vhost": "staging",
      "type": "topic",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    }
  ],

  "queues": [
    {
      "name": "app.order-processor",
      "vhost": "production",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-queue-type": "quorum",
        "x-delivery-limit": 5,
        "x-dead-letter-exchange": "dlx",
        "x-dead-letter-routing-key": "app.order-processor.dead"
      }
    },
    {
      "name": "app.payment-processor",
      "vhost": "production",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-queue-type": "quorum",
        "x-delivery-limit": 3,
        "x-dead-letter-exchange": "dlx",
        "x-dead-letter-routing-key": "app.payment-processor.dead"
      }
    },
    {
      "name": "app.notification-sender",
      "vhost": "production",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-queue-type": "quorum",
        "x-delivery-limit": 10,
        "x-dead-letter-exchange": "dlx",
        "x-dead-letter-routing-key": "app.notification-sender.dead"
      }
    },
    {
      "name": "app.analytics-collector",
      "vhost": "production",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-queue-type": "quorum",
        "x-max-length": 500000
      }
    },
    {
      "name": "dlq",
      "vhost": "production",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-queue-type": "quorum",
        "x-message-ttl": 604800000
      }
    },
    {
      "name": "app.order-processor",
      "vhost": "staging",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-queue-type": "quorum",
        "x-delivery-limit": 5,
        "x-dead-letter-exchange": "dlx"
      }
    },
    {
      "name": "dlq",
      "vhost": "staging",
      "durable": true,
      "auto_delete": false,
      "arguments": {
        "x-queue-type": "quorum",
        "x-message-ttl": 86400000
      }
    }
  ],

  "bindings": [
    {
      "source": "events",
      "vhost": "production",
      "destination": "app.order-processor",
      "destination_type": "queue",
      "routing_key": "order.#",
      "arguments": {}
    },
    {
      "source": "events",
      "vhost": "production",
      "destination": "app.analytics-collector",
      "destination_type": "queue",
      "routing_key": "#",
      "arguments": {}
    },
    {
      "source": "commands",
      "vhost": "production",
      "destination": "app.payment-processor",
      "destination_type": "queue",
      "routing_key": "payment.process",
      "arguments": {}
    },
    {
      "source": "notifications",
      "vhost": "production",
      "destination": "app.notification-sender",
      "destination_type": "queue",
      "routing_key": "",
      "arguments": {}
    },
    {
      "source": "dlx",
      "vhost": "production",
      "destination": "dlq",
      "destination_type": "queue",
      "routing_key": "#",
      "arguments": {}
    },
    {
      "source": "events",
      "vhost": "staging",
      "destination": "app.order-processor",
      "destination_type": "queue",
      "routing_key": "order.#",
      "arguments": {}
    },
    {
      "source": "dlx",
      "vhost": "staging",
      "destination": "dlq",
      "destination_type": "queue",
      "routing_key": "#",
      "arguments": {}
    }
  ],

  "policies": [
    {
      "vhost": "production",
      "name": "quorum-default",
      "pattern": "^app\\.",
      "apply-to": "queues",
      "definition": {
        "queue-type": "quorum"
      },
      "priority": 0
    },
    {
      "vhost": "production",
      "name": "dlq-ttl",
      "pattern": "^dlq",
      "apply-to": "queues",
      "definition": {
        "message-ttl": 604800000,
        "max-length": 1000000,
        "overflow": "reject-publish"
      },
      "priority": 1
    },
    {
      "vhost": "production",
      "name": "max-length-default",
      "pattern": "^app\\.",
      "apply-to": "queues",
      "definition": {
        "max-length": 500000,
        "overflow": "reject-publish-dlx"
      },
      "priority": 0
    },
    {
      "vhost": "staging",
      "name": "staging-ttl",
      "pattern": ".*",
      "apply-to": "queues",
      "definition": {
        "message-ttl": 86400000,
        "max-length": 100000,
        "overflow": "drop-head"
      },
      "priority": 0
    }
  ]
}
