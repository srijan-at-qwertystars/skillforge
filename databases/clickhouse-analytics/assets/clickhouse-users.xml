<!-- clickhouse-users.xml
     ClickHouse user configuration with profiles, quotas, and row-level security.
     Place in /etc/clickhouse-server/users.xml or /etc/clickhouse-server/users.d/
-->
<clickhouse>
    <!-- ================================================================== -->
    <!-- Settings Profiles                                                  -->
    <!-- ================================================================== -->
    <profiles>
        <!-- Default profile: applied to all users unless overridden -->
        <default>
            <max_memory_usage>20000000000</max_memory_usage>
            <max_execution_time>300</max_execution_time>
            <max_threads>16</max_threads>
            <max_block_size>65536</max_block_size>
            <use_uncompressed_cache>1</use_uncompressed_cache>
            <optimize_read_in_order>1</optimize_read_in_order>
            <compile_expressions>1</compile_expressions>
            <join_algorithm>auto</join_algorithm>
            <distributed_product_mode>global</distributed_product_mode>
            <load_balancing>random</load_balancing>
        </default>

        <!-- Read-only profile for dashboards and BI tools -->
        <readonly>
            <readonly>1</readonly>
            <max_memory_usage>10000000000</max_memory_usage>
            <max_execution_time>60</max_execution_time>
            <max_threads>8</max_threads>
            <max_result_rows>1000000</max_result_rows>
            <max_result_bytes>1000000000</max_result_bytes>
            <result_overflow_mode>break</result_overflow_mode>
        </readonly>

        <!-- Write-heavy profile for ingestion pipelines -->
        <ingestion>
            <max_memory_usage>30000000000</max_memory_usage>
            <max_execution_time>600</max_execution_time>
            <max_threads>4</max_threads>
            <max_insert_block_size>1048576</max_insert_block_size>
            <min_insert_block_size_rows>1048576</min_insert_block_size_rows>
            <max_partitions_per_insert_block>100</max_partitions_per_insert_block>
            <async_insert>1</async_insert>
            <wait_for_async_insert>1</wait_for_async_insert>
            <async_insert_max_data_size>10485760</async_insert_max_data_size>
            <async_insert_busy_timeout_ms>5000</async_insert_busy_timeout_ms>
        </ingestion>

        <!-- Analyst profile: generous limits for ad-hoc queries -->
        <analyst>
            <max_memory_usage>40000000000</max_memory_usage>
            <max_execution_time>600</max_execution_time>
            <max_threads>16</max_threads>
            <max_bytes_before_external_group_by>10000000000</max_bytes_before_external_group_by>
            <max_bytes_before_external_sort>10000000000</max_bytes_before_external_sort>
            <join_algorithm>auto</join_algorithm>
        </analyst>
    </profiles>

    <!-- ================================================================== -->
    <!-- Users                                                              -->
    <!-- ================================================================== -->
    <users>
        <!-- Admin user -->
        <default>
            <password_sha256_hex><!-- sha256 hash of password --></password_sha256_hex>
            <profile>default</profile>
            <quota>default</quota>
            <networks>
                <ip>::/0</ip>
            </networks>
            <access_management>1</access_management>
        </default>

        <!-- Dashboard/BI tool user (read-only) -->
        <grafana>
            <password_sha256_hex><!-- sha256 hash of password --></password_sha256_hex>
            <profile>readonly</profile>
            <quota>dashboard</quota>
            <networks>
                <ip>10.0.0.0/8</ip>
                <ip>172.16.0.0/12</ip>
            </networks>
            <databases>
                <analytics>
                    <table>daily_metrics</table>
                    <table>events</table>
                </analytics>
            </databases>
        </grafana>

        <!-- Data ingestion service account -->
        <ingestion_svc>
            <password_sha256_hex><!-- sha256 hash of password --></password_sha256_hex>
            <profile>ingestion</profile>
            <quota>ingestion</quota>
            <networks>
                <ip>10.0.0.0/8</ip>
            </networks>
            <!-- Grant insert-only access to specific tables -->
            <allow_databases>
                <database>analytics</database>
            </allow_databases>
        </ingestion_svc>

        <!-- Analyst user with row-level security -->
        <analyst_us>
            <password_sha256_hex><!-- sha256 hash of password --></password_sha256_hex>
            <profile>analyst</profile>
            <quota>analyst</quota>
            <networks>
                <ip>::/0</ip>
            </networks>
        </analyst_us>

        <!-- Analyst user for EU data only -->
        <analyst_eu>
            <password_sha256_hex><!-- sha256 hash of password --></password_sha256_hex>
            <profile>analyst</profile>
            <quota>analyst</quota>
            <networks>
                <ip>::/0</ip>
            </networks>
        </analyst_eu>
    </users>

    <!-- ================================================================== -->
    <!-- Quotas                                                             -->
    <!-- ================================================================== -->
    <quotas>
        <!-- Default quota: no hard limits -->
        <default>
            <interval>
                <duration>3600</duration>
                <queries>0</queries>
                <errors>0</errors>
                <result_rows>0</result_rows>
                <read_rows>0</read_rows>
                <execution_time>0</execution_time>
            </interval>
        </default>

        <!-- Dashboard quota: rate-limited for automated tools -->
        <dashboard>
            <interval>
                <duration>60</duration>
                <queries>100</queries>
                <errors>10</errors>
                <result_rows>10000000</result_rows>
                <read_rows>1000000000</read_rows>
                <execution_time>300</execution_time>
            </interval>
        </dashboard>

        <!-- Ingestion quota: generous for data pipelines -->
        <ingestion>
            <interval>
                <duration>3600</duration>
                <queries>10000</queries>
                <errors>100</errors>
                <result_rows>0</result_rows>
                <read_rows>0</read_rows>
                <execution_time>0</execution_time>
            </interval>
        </ingestion>

        <!-- Analyst quota: reasonable limits for interactive use -->
        <analyst>
            <interval>
                <duration>3600</duration>
                <queries>500</queries>
                <errors>50</errors>
                <result_rows>100000000</result_rows>
                <read_rows>10000000000</read_rows>
                <execution_time>3600</execution_time>
            </interval>
        </analyst>
    </quotas>

    <!-- ================================================================== -->
    <!-- Row-Level Security (Row Policies)                                  -->
    <!-- ================================================================== -->
    <!--
    Row policies are created via SQL, not XML. Execute these after server starts:

    -- US analyst can only see US data
    CREATE ROW POLICY policy_us_only ON analytics.events
    FOR SELECT USING user_country = 'US'
    TO analyst_us;

    -- EU analyst can only see EU data
    CREATE ROW POLICY policy_eu_only ON analytics.events
    FOR SELECT USING user_country IN ('DE', 'FR', 'GB', 'IT', 'ES', 'NL', 'PL', 'SE', 'AT', 'BE', 'IE')
    TO analyst_eu;

    -- Admin sees everything (permissive policy)
    CREATE ROW POLICY policy_admin_all ON analytics.events
    FOR SELECT USING 1
    TO default;

    -- Verify policies
    SHOW ROW POLICIES ON analytics.events;

    -- Column-level restrictions (GRANT based):
    GRANT SELECT(event_date, event_type, user_country, event_count) ON analytics.daily_metrics TO grafana;
    REVOKE SELECT(properties, session_id, device_id) ON analytics.events FROM analyst_us;
    -->
</clickhouse>
