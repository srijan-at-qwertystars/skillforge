<!-- clickhouse-server-config.xml
     Production ClickHouse server configuration with recommended settings.
     Place in /etc/clickhouse-server/config.d/production.xml or merge into config.xml.
-->
<clickhouse>
    <!-- ================================================================== -->
    <!-- Network and Protocol                                               -->
    <!-- ================================================================== -->
    <http_port>8123</http_port>
    <tcp_port>9000</tcp_port>
    <interserver_http_port>9009</interserver_http_port>

    <!-- TLS (uncomment for production) -->
    <!-- <https_port>8443</https_port> -->
    <!-- <tcp_port_secure>9440</tcp_port_secure> -->
    <!-- <openSSL>
        <server>
            <certificateFile>/etc/clickhouse-server/ssl/server.crt</certificateFile>
            <privateKeyFile>/etc/clickhouse-server/ssl/server.key</privateKeyFile>
            <caConfig>/etc/clickhouse-server/ssl/ca.crt</caConfig>
        </server>
    </openSSL> -->

    <listen_host>0.0.0.0</listen_host>
    <max_connections>4096</max_connections>
    <keep_alive_timeout>10</keep_alive_timeout>

    <!-- ================================================================== -->
    <!-- Concurrency and Query Limits                                       -->
    <!-- ================================================================== -->
    <max_concurrent_queries>200</max_concurrent_queries>
    <max_concurrent_insert_queries>50</max_concurrent_insert_queries>
    <max_concurrent_select_queries>150</max_concurrent_select_queries>

    <!-- ================================================================== -->
    <!-- Memory Limits                                                      -->
    <!-- ================================================================== -->
    <!-- Server-wide memory cap: 80% of available RAM -->
    <max_server_memory_usage_to_ram_ratio>0.8</max_server_memory_usage_to_ram_ratio>

    <!-- Per-query memory limit (override per-user in users.xml) -->
    <!-- <max_memory_usage>20000000000</max_memory_usage> -->

    <!-- ================================================================== -->
    <!-- Data Paths                                                         -->
    <!-- ================================================================== -->
    <path>/var/lib/clickhouse/</path>
    <tmp_path>/var/lib/clickhouse/tmp/</tmp_path>
    <user_files_path>/var/lib/clickhouse/user_files/</user_files_path>
    <format_schema_path>/var/lib/clickhouse/format_schemas/</format_schema_path>

    <!-- ================================================================== -->
    <!-- Logging                                                            -->
    <!-- ================================================================== -->
    <logger>
        <level>information</level>
        <log>/var/log/clickhouse-server/clickhouse-server.log</log>
        <errorlog>/var/log/clickhouse-server/clickhouse-server.err.log</errorlog>
        <size>1000M</size>
        <count>10</count>
        <console>0</console>
    </logger>

    <!-- Query log (persisted for diagnostics) -->
    <query_log>
        <database>system</database>
        <table>query_log</table>
        <flush_interval_milliseconds>7500</flush_interval_milliseconds>
        <partition_by>toYYYYMM(event_date)</partition_by>
        <ttl>event_date + INTERVAL 30 DAY DELETE</ttl>
    </query_log>

    <query_thread_log>
        <database>system</database>
        <table>query_thread_log</table>
        <flush_interval_milliseconds>7500</flush_interval_milliseconds>
        <partition_by>toYYYYMM(event_date)</partition_by>
        <ttl>event_date + INTERVAL 14 DAY DELETE</ttl>
    </query_thread_log>

    <part_log>
        <database>system</database>
        <table>part_log</table>
        <flush_interval_milliseconds>7500</flush_interval_milliseconds>
        <partition_by>toYYYYMM(event_date)</partition_by>
        <ttl>event_date + INTERVAL 30 DAY DELETE</ttl>
    </part_log>

    <trace_log>
        <database>system</database>
        <table>trace_log</table>
        <flush_interval_milliseconds>7500</flush_interval_milliseconds>
        <partition_by>toYYYYMM(event_date)</partition_by>
        <ttl>event_date + INTERVAL 7 DAY DELETE</ttl>
    </trace_log>

    <!-- ================================================================== -->
    <!-- MergeTree Engine Settings                                          -->
    <!-- ================================================================== -->
    <merge_tree>
        <!-- Merge parallelism: set to number of CPU cores -->
        <background_pool_size>16</background_pool_size>
        <background_move_pool_size>8</background_move_pool_size>
        <background_schedule_pool_size>16</background_schedule_pool_size>

        <!-- Part explosion protection -->
        <parts_to_throw_insert>300</parts_to_throw_insert>
        <parts_to_delay_insert>150</parts_to_delay_insert>
        <max_delay_to_insert>60</max_delay_to_insert>
        <max_parts_in_total>100000</max_parts_in_total>

        <!-- Merge behavior -->
        <max_bytes_to_merge_at_max_space_in_pool>161061273600</max_bytes_to_merge_at_max_space_in_pool>
        <number_of_free_entries_in_pool_to_lower_max_size_of_merge>8</number_of_free_entries_in_pool_to_lower_max_size_of_merge>
        <max_suspicious_broken_parts>20</max_suspicious_broken_parts>

        <!-- Wide part threshold (use wide format for larger parts) -->
        <min_bytes_for_wide_part>10485760</min_bytes_for_wide_part>
        <min_rows_for_wide_part>0</min_rows_for_wide_part>
    </merge_tree>

    <!-- ================================================================== -->
    <!-- Compression                                                        -->
    <!-- ================================================================== -->
    <compression>
        <!-- Use LZ4 for smaller parts (fast compression) -->
        <case>
            <min_part_size>0</min_part_size>
            <min_part_size_ratio>0</min_part_size_ratio>
            <method>lz4</method>
        </case>
        <!-- Use ZSTD for larger parts (better ratio) -->
        <case>
            <min_part_size>10000000000</min_part_size>
            <min_part_size_ratio>0.01</min_part_size_ratio>
            <method>zstd</method>
            <level>3</level>
        </case>
    </compression>

    <!-- ================================================================== -->
    <!-- Storage Policies (hot/cold tiering)                                -->
    <!-- ================================================================== -->
    <storage_configuration>
        <disks>
            <default>
                <path>/var/lib/clickhouse/</path>
            </default>
            <!-- Uncomment for tiered storage:
            <cold>
                <path>/mnt/hdd/clickhouse/</path>
            </cold>
            <s3_storage>
                <type>s3</type>
                <endpoint>https://s3.amazonaws.com/my-bucket/clickhouse/</endpoint>
                <access_key_id>KEY</access_key_id>
                <secret_access_key>SECRET</secret_access_key>
            </s3_storage>
            -->
        </disks>
        <policies>
            <default>
                <volumes>
                    <main>
                        <disk>default</disk>
                    </main>
                </volumes>
            </default>
            <!-- Uncomment for tiered storage:
            <tiered>
                <volumes>
                    <hot>
                        <disk>default</disk>
                        <max_data_part_size_bytes>10737418240</max_data_part_size_bytes>
                    </hot>
                    <cold>
                        <disk>cold</disk>
                    </cold>
                </volumes>
                <move_factor>0.1</move_factor>
            </tiered>
            -->
        </policies>
    </storage_configuration>

    <!-- ================================================================== -->
    <!-- Distributed Query Settings                                         -->
    <!-- ================================================================== -->
    <distributed_ddl>
        <path>/clickhouse/task_queue/ddl</path>
        <cleanup_delay_period>60</cleanup_delay_period>
        <task_max_lifetime>86400</task_max_lifetime>
    </distributed_ddl>

    <!-- ================================================================== -->
    <!-- ZooKeeper / ClickHouse Keeper Connection                           -->
    <!-- ================================================================== -->
    <!-- Uncomment and configure for replicated tables:
    <zookeeper>
        <node>
            <host>keeper1.internal</host>
            <port>9181</port>
        </node>
        <node>
            <host>keeper2.internal</host>
            <port>9181</port>
        </node>
        <node>
            <host>keeper3.internal</host>
            <port>9181</port>
        </node>
        <session_timeout_ms>30000</session_timeout_ms>
        <operation_timeout_ms>10000</operation_timeout_ms>
    </zookeeper>

    <macros>
        <shard>01</shard>
        <replica>replica_01</replica>
        <cluster>analytics_cluster</cluster>
    </macros>
    -->

    <!-- ================================================================== -->
    <!-- Async Inserts (server-side batching)                               -->
    <!-- ================================================================== -->
    <!-- Enable globally or per-user in users.xml -->
    <!-- <async_insert>1</async_insert> -->
    <!-- <async_insert_max_data_size>10485760</async_insert_max_data_size> -->
    <!-- <async_insert_busy_timeout_ms>5000</async_insert_busy_timeout_ms> -->

    <!-- ================================================================== -->
    <!-- Builtin Dictionaries                                               -->
    <!-- ================================================================== -->
    <dictionaries_config>*_dictionary.xml</dictionaries_config>
    <dictionaries_lazy_load>true</dictionaries_lazy_load>

    <!-- ================================================================== -->
    <!-- User Configuration Files                                           -->
    <!-- ================================================================== -->
    <users_config>users.xml</users_config>
</clickhouse>
