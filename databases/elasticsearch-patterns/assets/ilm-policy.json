{
  "_comment": "Hot-Warm-Cold ILM policy — apply with PUT _ilm/policy/tiered_lifecycle",
  "_usage": "Attach to index template via: index.lifecycle.name = tiered_lifecycle",
  "policy": {
    "phases": {
      "hot": {
        "min_age": "0ms",
        "actions": {
          "rollover": {
            "max_primary_shard_size": "50gb",
            "max_age": "7d",
            "max_docs": 200000000
          },
          "set_priority": {
            "priority": 100
          }
        }
      },
      "warm": {
        "min_age": "30d",
        "actions": {
          "set_priority": {
            "priority": 50
          },
          "shrink": {
            "number_of_shards": 1
          },
          "forcemerge": {
            "max_num_segments": 1
          },
          "allocate": {
            "number_of_replicas": 1,
            "require": {
              "data": "warm"
            }
          },
          "readonly": {}
        }
      },
      "cold": {
        "min_age": "90d",
        "actions": {
          "set_priority": {
            "priority": 0
          },
          "allocate": {
            "number_of_replicas": 0,
            "require": {
              "data": "cold"
            }
          },
          "searchable_snapshot": {
            "snapshot_repository": "cold_snapshot_repo",
            "force_merge_index": true
          }
        }
      },
      "frozen": {
        "min_age": "180d",
        "actions": {
          "searchable_snapshot": {
            "snapshot_repository": "frozen_snapshot_repo"
          }
        }
      },
      "delete": {
        "min_age": "365d",
        "actions": {
          "wait_for_snapshot": {
            "policy": "nightly_backup"
          },
          "delete": {}
        }
      }
    },
    "_meta": {
      "description": "Hot-warm-cold-frozen-delete lifecycle for time-series data",
      "version": 1,
      "managed_by": "platform-team",
      "notes": {
        "hot": "NVMe SSD, 7-day rollover or 50GB per primary shard",
        "warm": "SSD/HDD, shrink to 1 shard, force merge, read-only after 30d",
        "cold": "Searchable snapshot on cold tier after 90d, 0 replicas",
        "frozen": "Shared-cache searchable snapshot after 180d (cheapest searchable)",
        "delete": "Delete after 365d, but wait for nightly backup snapshot first"
      },
      "prerequisites": [
        "Create snapshot repositories: cold_snapshot_repo, frozen_snapshot_repo",
        "Configure SLM policy: nightly_backup",
        "Ensure nodes have correct data tier roles: data_hot, data_warm, data_cold, data_frozen",
        "Bootstrap write index with alias: POST /<alias>/_rollover"
      ]
    }
  }
}
