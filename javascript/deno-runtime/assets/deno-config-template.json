{
  "$schema": "https://deno.land/x/deno/cli/schemas/config-file.v1.json",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "lib": ["deno.window"],
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1",
    "@std/path": "jsr:@std/path@^1",
    "@std/fs": "jsr:@std/fs@^1",
    "@std/http": "jsr:@std/http@^1",
    "@std/dotenv": "jsr:@std/dotenv@^0.225",
    "@std/async": "jsr:@std/async@^1",
    "@std/collections": "jsr:@std/collections@^1",
    "@std/crypto": "jsr:@std/crypto@^1",
    "@std/encoding": "jsr:@std/encoding@^1",
    "@std/streams": "jsr:@std/streams@^1",
    "@std/uuid": "jsr:@std/uuid@^1",
    "@std/log": "jsr:@std/log@^0.224",
    "@/": "./src/",
    "#lib/": "./lib/"
  },
  "tasks": {
    "dev": "deno run --watch --allow-net --allow-read --allow-env src/main.ts",
    "start": "deno run --allow-net --allow-read --allow-env src/main.ts",
    "test": "deno test --allow-read --allow-net --allow-env",
    "test:watch": "deno test --watch --allow-read --allow-net --allow-env",
    "test:coverage": "deno test --coverage=cov_profile && deno coverage cov_profile",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "check": "deno check src/main.ts",
    "compile": "deno compile --output=build/app --allow-net --allow-read --allow-env src/main.ts",
    "bench": "deno bench",
    "deps:update": "deno outdated --update",
    "deps:check": "deno outdated"
  },
  "lint": {
    "rules": {
      "tags": ["recommended"],
      "exclude": ["no-unused-vars"]
    },
    "include": ["src/", "tests/", "lib/"],
    "exclude": ["build/", "node_modules/", "coverage/"]
  },
  "fmt": {
    "indentWidth": 2,
    "lineWidth": 100,
    "singleQuote": true,
    "semiColons": true,
    "proseWrap": "preserve",
    "include": ["src/", "tests/", "lib/"],
    "exclude": ["build/", "node_modules/", "coverage/"]
  },
  "test": {
    "include": ["tests/", "src/**/*_test.ts"],
    "exclude": ["build/", "node_modules/"]
  },
  "bench": {
    "include": ["bench/"],
    "exclude": ["build/", "node_modules/"]
  },
  "exclude": [
    "node_modules/",
    "build/",
    "dist/",
    "coverage/",
    "cov_profile/",
    ".git/"
  ],
  "lock": true,
  "nodeModulesDir": "none"
}
